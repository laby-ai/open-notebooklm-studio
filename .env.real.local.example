# Private local file for real smoke tests.
# Copy to .env.real.local and fill locally. Do not commit the real file.

APP_RUNTIME_ENV=production
FILE_STORAGE_ADAPTER=local

# Account and billing center. Public URL should point to the ordinary
# application portal; keep admin bootstrap and registration out of the user
# entry path.
ACCOUNT_CENTER_PUBLIC_URL=
NEXT_PUBLIC_ACCOUNT_CENTER_URL=
ACCOUNT_CENTER_API_BASE=
ACCOUNT_CENTER_TENANT_ID=
ACCOUNT_CENTER_DEFAULT_MEMBER_ID=

# Ark / OpenAI-compatible model service
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
ARK_MODEL=doubao-seed-1-6-251015
ARK_VISION_MODEL=doubao-seed-1-6-vision-250815
ARK_IMAGE_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# Image generation may require the Agent Plan personal key; leave empty to let
# the runtime fall back to ARK_AGENTPLAN_API_KEY, then ARK_API_KEY.
ARK_IMAGE_API_KEY=
ARK_IMAGE_MODEL=doubao-seedream-5-0-lite-260128
ARK_EMBEDDING_MODEL=

# Agent Plan text/TTS service. Use the personal Agent Plan key here; do not
# assume the regular Ark key can access /api/plan/v3.
ARK_AGENTPLAN_API_BASE=https://ark.cn-beijing.volces.com/api/plan/v3
ARK_AGENTPLAN_API_KEY=
ARK_AGENTPLAN_TEXT_MODEL=glm-5.2
AI_TEST_CONFIG_TEXT_TIMEOUT_MS=45000
AI_TEST_CONFIG_VISION_TIMEOUT_MS=60000
AI_TEST_CONFIG_EMBEDDING_TIMEOUT_MS=30000

# Real podcast audio smoke. This uses the VolcEngine/ByteDance Doubao Podcast
# WebSocket v3 API. Keep access keys in private env only.
VOLCENGINE_PODCAST_WS_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sami/podcasttts
VOLCENGINE_PODCAST_APP_ID=
VOLCENGINE_PODCAST_ACCESS_KEY=
VOLCENGINE_PODCAST_RESOURCE_ID=volc.service_type.10050
VOLCENGINE_PODCAST_APP_KEY=aGjiRDfUWi
VOLCENGINE_PODCAST_SPEAKERS=zh_male_dayixiansheng_v2_saturn_bigtts,zh_female_mizaitongxue_v2_saturn_bigtts
VOLCENGINE_PODCAST_FORMAT=mp3
VOLCENGINE_PODCAST_SAMPLE_RATE=24000
VOLCENGINE_PODCAST_TIMEOUT_MS=180000

# Default real podcast audio path: Doubao AgentPlan TTS. The official endpoint
# domain is openspeech.bytedance.com, but product/runtime config should use the
# AgentPlan/Doubao names below.
AGENTPLAN_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/plan/tts/unidirectional
AGENTPLAN_TTS_RESOURCE_ID=seed-tts-2.0
AGENTPLAN_TTS_API_KEY=
AGENTPLAN_TTS_SPEAKER=
AGENTPLAN_TTS_FORMAT=mp3
AGENTPLAN_TTS_SAMPLE_RATE=24000
AGENTPLAN_TTS_TIMEOUT_MS=90000

# Real Studio product smoke guardrails
REAL_STUDIO_UPLOAD_TIMEOUT_MS=120000
REAL_STUDIO_CARDS_TIMEOUT_MS=120000
REAL_STUDIO_REPORT_TIMEOUT_MS=120000
REAL_STUDIO_PODCAST_CONTEXT_TIMEOUT_MS=30000
REAL_STUDIO_PODCAST_AUDIO_TIMEOUT_MS=120000
REAL_STUDIO_PPT_TIMEOUT_MS=420000
REAL_STUDIO_PPT_DURATION_MIN=5
REAL_PPT_TIMEOUT_MS=600000
PPT_V2_FILL_SLIDE_TIMEOUT_MS=120000

# Full real Studio smoke can take 7-10 minutes because it runs upload,
# cards, report, podcast audio, and PPT-v2 sequentially. Set false when
# you only want cards/report/podcast grounded checks, then run
# pnpm generate:real-ppt-v2 && pnpm audit:pptx-quality separately.
REAL_STUDIO_INCLUDE_PPT=true
